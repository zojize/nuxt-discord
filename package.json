{
  "name": "nuxt-discord",
  "type": "module",
  "version": "0.0.17",
  "packageManager": "bun@1.3.0",
  "description": "A Nuxt module for building Discord bots",
  "author": "Jize Zou <jeffzou2001@gmail.com> (https://github.com/zojize)",
  "license": "MIT",
  "repository": "git+https://github.com/zojize/nuxt-discord.git",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "discord",
    "discord-bot"
  ],
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts"
    },
    "./*": "./*"
  },
  "main": "./dist/module.mjs",
  "types": "./dist/module.d.mts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "bun run dev:prepare && nuxi dev playground",
    "dev:debug": "bun run dev:prepare && node --inspect ./node_modules/nuxt/bin/nuxt.mjs dev playground --no-fork",
    "dev:build": "nuxi build playground",
    "dev:docs": "nuxi dev docs --port 4000",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "bun run lint && bun run test && bun run prepack && changelogen --release && bun publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "discord.js": "^14.26.0"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.101",
    "@iconify-json/simple-icons": "^1.2.76",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/ui": "^4.6.0",
    "ansis": "^4.2.0",
    "chokidar": "^5.0.0",
    "defu": "^6.1.4",
    "knitwork": "^1.3.0",
    "listhen": "^1.9.0",
    "rollup": "^4.60.1",
    "simple-icons": "^16.14.0",
    "tailwindcss": "^4.2.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@nuxt/devtools": "^4.0.0-alpha.3",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "^24.0.15",
    "@types/ws": "^8.18.1",
    "@vueuse/core": "^14.2.1",
    "changelogen": "^0.6.2",
    "eslint": "^10.1.0",
    "knip": "^6.2.0",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.2",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6"
  },
  "workspaces": [
    "playground",
    "docs"
  ],
  "resolutions": {
    "nuxt-discord": "link:."
  },
  "simple-git-hooks": {
    "pre-commit": "bun install --frozen-lockfile && bunx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
